{
  // OpenClaw config for local vLLM instance running Qwen3-Coder-30B-FP8
  // Host: 192.168.0.187:8000  |  Served via: vLLM with Hermes tool-call parser
  // Context window capped at 32768 (hardware limit; OpenClaw recommends 64K but we override here)

  "agents": {
    "defaults": {
      "model": {
        // Primary model reference uses the format: <provider-name>/<model-id>
        "primary": "vllm/qwen3-coder-30b-fp8"
      },
      "models": {
        // Register the model in the allowlist so OpenClaw accepts it
        "vllm/qwen3-coder-30b-fp8": {
          "alias": "qwen3-coder"
        }
      },
      "contextPruning": {
        // Prune aggressively given the 32K context limit
        // cache-ttl mode keeps the prompt cache valid and drops old tool results automatically
        "mode": "cache-ttl",
        "ttl": "6h",
        "keepLastAssistants": 3
      },
      "compaction": {
        // Flush session memory to disk when nearing the context limit
        // softThresholdTokens set conservatively below 32768 to leave headroom for responses
        "mode": "default",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 24000,
          "prompt": "Extract key decisions, state changes, lessons, and blockers to memory/YYYY-MM-DD.md. Format: ## [HH:MM] Topic. Skip routine exchanges. Write NO_FLUSH if nothing important happened.",
          "systemPrompt": "Compacting session context. Extract only what is worth remembering. No fluff."
        }
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
        "default": true
      }
    ]
  },

  "models": {
    "mode": "merge",
    "providers": {
      "vllm": {
        // Point to the remote vLLM instance on your LAN
        "baseUrl": "http://192.168.0.187:8000/v1",

        // vLLM was started with VLLM_API_KEY not set, so any non-empty string works.
        // Set the env var VLLM_API_KEY="vllm-local" on the OpenClaw host, or hard-code below.
        "apiKey": "${VLLM_API_KEY}",

        // vLLM exposes an OpenAI-compatible /v1/chat/completions endpoint
        "api": "openai-completions",

        "models": [
          {
            // Must exactly match the model name vLLM was given at serve time:
            //   vllm serve qwen3-coder-30b-fp8 ...
            "id": "qwen3-coder-30b-fp8",
            "name": "Qwen3-Coder-30B FP8 (local vLLM)",

            // Qwen3 supports extended thinking/reasoning
            "reasoning": true,

            "input": ["text"],

            // Local inference: no per-token cost
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },

            // Hardware cap — your vLLM is started with --max-model-len 32768
            // OpenClaw recommends 64K but we pin the real limit here to avoid
            // silent truncation or rejected requests from the server
            "contextWindow": 32768,

            // Keep max output tokens well below the context window.
            // vLLM was started with --max-num-batched-tokens 8192 so cap here too.
            "maxTokens": 8192,

            // Tool calling: vLLM was started with:
            //   --enable-auto-tool-choice --tool-call-parser hermes
            // This means vLLM handles tool-call formatting natively.
            // OpenClaw will send tools in standard OpenAI format and vLLM converts them.
            "params": {
              // Do NOT disable streaming — vLLM + Hermes supports streaming + tools
              "streaming": true
            }
          }
        ]
      }
    }
  },

  "gateway": {
    // Bind to loopback for security — use SSH tunnel or Tailscale for remote access
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      // Replace with a strong random string: openssl rand -hex 24
      "token": "REPLACE_WITH_YOUR_GATEWAY_TOKEN"
    }
  },

  "logging": {
    // Redact sensitive values (API keys, tokens) from tool output in logs
    "redactSensitive": "tools"
  }
}
